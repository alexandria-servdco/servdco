# =============================================================================
# ServdCo — Environment Variables
# Copy to .env.local for local dev. For production, set these in Vercel only.
# NEVER commit .env.local or real secrets to GitHub.
# =============================================================================

# -----------------------------------------------------------------------------
# CLIENT (VITE_* — baked into the browser bundle at build time)
# Set ALL of these in Vercel → Project → Settings → Environment Variables
# Scope: Production (and Preview if you want staging)
# -----------------------------------------------------------------------------

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Production: set both to true
VITE_USE_SUPABASE_AUTH=true
VITE_ENABLE_STRIPE_CHECKOUT=true
VITE_ENABLE_MESSAGING=false

# Cloudflare Turnstile (public site key — safe in client bundle)
VITE_TURNSTILE_SITE_KEY=

# Optional — enable when Google OAuth is configured in Supabase
# VITE_ENABLE_GOOGLE_OAUTH=false

# -----------------------------------------------------------------------------
# SERVER (Vercel serverless /api/* only — NOT exposed to browser)
# Scope: Production (and Preview)
# Mark STRIPE_*, SUPABASE_SERVICE_ROLE_KEY, CRON_SECRET as "Sensitive" in Vercel
# -----------------------------------------------------------------------------

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET
# Local only — from `stripe listen` output; overrides STRIPE_WEBHOOK_SECRET when set
STRIPE_WEBHOOK_SECRET_LOCAL=
STRIPE_PREMIUM_PRODUCT_ID=prod_YOUR_PREMIUM_PRODUCT_ID
STRIPE_PREMIUM_PRICE_ID=price_YOUR_PREMIUM_PRICE_ID

ENABLE_STRIPE_CHECKOUT=true
CRON_SECRET=generate-with-openssl-rand-hex-32

# Cloudflare Turnstile secret (server-only)
TURNSTILE_SECRET_KEY=

# -----------------------------------------------------------------------------
# LOCAL ONLY — do NOT add to Vercel
# -----------------------------------------------------------------------------

# Direct Postgres URL for migrations CLI only (supabase db push)
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Dev seed scripts — never enable in production
ALLOW_DEV_SEED=false

# Optional — not used (Connect uses accountLinks, not OAuth)
# STRIPE_CONNECT_CLIENT_ID=ca_YOUR_STRIPE_CONNECT_CLIENT_ID
