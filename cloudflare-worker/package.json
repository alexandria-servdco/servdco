{
  "name": "servdco-cron",
  "version": "2.0.0",
  "private": true,
  "description": "Cloudflare Worker cron scheduler for ServdCo reconciliation jobs. Pure HTTP scheduler — no business logic.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "tail": "wrangler tail",
    "trigger": "wrangler dev --test-scheduled"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.14.0+sha512.ad27a79641b49c3e481a16a805baa71817a04bbe06a38d17e60e2eaee83f6a146c6a688125f5792e48dd5ba30e7da52a5cda4c3992b9ccf333f9ce223af84748",
  "dependencies": {
    "wrangler": "^3.114.17"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "typescript": "^5.6.0"
  }
}
