{
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30,
      "includeFiles": "lib/**,shared/**,api/_lib/**"
    }
  },
  "crons": [
    {
      "path": "/api/stripe/transfers/process",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/stripe/payments/reconcile-batch",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/stripe/subscription/reconcile-batch",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/launch/auto-check",
      "schedule": "0 6 * * *"
    }
  ],
  "_comment_stripe_rewrites": "Public Stripe paths are mapped to the single consolidated dispatcher api/stripe/[action].ts to stay under the Vercel Hobby 12-function limit. /api/stripe/webhook is intentionally excluded and remains its own function (raw body + Stripe-registered URL).",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://js.stripe.com https://www.googletagmanager.com https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https: https://www.google-analytics.com https://www.googletagmanager.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.stripe.com https://challenges.cloudflare.com https://www.google-analytics.com https://region1.google-analytics.com https://*.google-analytics.com https://www.googletagmanager.com https://*.ingest.sentry.io https://*.ingest.us.sentry.io; frame-src 'self' https://js.stripe.com https://hooks.stripe.com https://*.supabase.co https://challenges.cloudflare.com blob:; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/stripe/payments/reconcile",
      "destination": "/api/stripe/[action]?action=payments-reconcile"
    },
    {
      "source": "/api/stripe/payments/reconcile-batch",
      "destination": "/api/stripe/[action]?action=payments-reconcile-batch"
    },
    {
      "source": "/api/stripe/subscription/checkout-session",
      "destination": "/api/stripe/[action]?action=subscription-checkout-session"
    },
    {
      "source": "/api/stripe/subscription/reconcile",
      "destination": "/api/stripe/[action]?action=subscription-reconcile"
    },
    {
      "source": "/api/stripe/subscription/reconcile-batch",
      "destination": "/api/stripe/[action]?action=subscription-reconcile-batch"
    },
    {
      "source": "/api/stripe/tips/create-checkout-session",
      "destination": "/api/stripe/[action]?action=tips-create-checkout-session"
    },
    {
      "source": "/api/stripe/transfers/process",
      "destination": "/api/stripe/[action]?action=transfers-process"
    },
    {
      "source": "/api/stripe/connect/onboarding",
      "destination": "/api/stripe/[action]?action=connect-onboarding"
    },
    {
      "source": "/api/stripe/connect/dashboard-link",
      "destination": "/api/stripe/[action]?action=connect-dashboard-link"
    },
    {
      "source": "/api/stripe/connect/sync",
      "destination": "/api/stripe/[action]?action=connect-sync"
    },
    {
      "source": "/api/stripe/create-checkout-session",
      "destination": "/api/stripe/[action]?action=create-checkout-session"
    },
    {
      "source": "/api/stripe/refund",
      "destination": "/api/stripe/[action]?action=refund"
    },
    {
      "source": "/api/admin/payment-ledger",
      "destination": "/api/admin/[action]?action=payment-ledger"
    },
    {
      "source": "/api/contact/submit",
      "destination": "/api/platform/contact-submit"
    },
    {
      "source": "/api/emails/booking-event",
      "destination": "/api/platform/booking-event"
    },
    {
      "source": "/api/careers/application-notify",
      "destination": "/api/platform/careers-application-notify"
    },
    {
      "source": "/api/documents/submit-notify",
      "destination": "/api/platform/document-submit-notify"
    },
    {
      "source": "/api/waitlist/submit",
      "destination": "/api/platform/waitlist"
    },
    {
      "source": "/api/security/enforce",
      "destination": "/api/platform/enforce"
    },
    {
      "source": "/api/launch/resolve",
      "destination": "/api/platform/launch-resolve"
    },
    {
      "source": "/api/launch/sync-user",
      "destination": "/api/platform/launch-sync-user"
    },
    {
      "source": "/api/launch/lifecycle",
      "destination": "/api/platform/launch-lifecycle"
    },
    {
      "source": "/api/launch/auto-check",
      "destination": "/api/platform/launch-auto-check"
    },
    {
      "source": "/api/location/reverse",
      "destination": "/api/platform/location-reverse"
    },
    {
      "source": "/api/location/update",
      "destination": "/api/platform/location-update"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
